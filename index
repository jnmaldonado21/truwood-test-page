<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
<title>Truwood Pilot — The Forest Watch</title>
<link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;1,9..40,300&display=swap" rel="stylesheet">
<script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/gsap.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/ScrollTrigger.min.js"></script>
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
:root{
  --deep:#01090505;
  --deep:#010905;
  --forest:#041A0C;
  --mid:#083A1A;
  --bright:#00E580;
  --teal:#00C4CC;
  --ice:#A8F0D8;
  --text:#D8F2E8;
  --muted:#3D7A58;
  --dim:#1A3828;
}
html{scroll-behavior:auto;font-size:16px}
body{background:var(--deep);color:var(--text);font-family:'DM Sans',sans-serif;font-weight:300;overflow-x:hidden;min-height:100vh}

/* ─── FOREST BACKGROUND ───────────────────────────── */
#forest-bg{position:fixed;inset:0;z-index:0;overflow:hidden;pointer-events:none}
.tree-layer{position:absolute;bottom:0;left:-20%;width:140%;height:100%;will-change:transform}
.tree-layer.far{opacity:.12;filter:blur(1.5px)}
.tree-layer.mid{opacity:.22;filter:blur(.6px)}
.tree-layer.near{opacity:.38}
.light-shafts{position:absolute;inset:0;overflow:hidden;opacity:.07}
.shaft{position:absolute;top:-10%;width:60px;height:130%;background:linear-gradient(to bottom,rgba(0,229,128,.9),transparent);transform:skewX(-18deg);animation:shaftDrift linear infinite}
@keyframes shaftDrift{0%{transform:skewX(-18deg) translateX(0)}100%{transform:skewX(-18deg) translateX(30vw)}}
.particles{position:absolute;inset:0;overflow:hidden}
.pt{position:absolute;border-radius:50%;background:var(--bright);animation:ptFloat ease-in-out infinite;opacity:0}
@keyframes ptFloat{
  0%{opacity:0;transform:translateY(0) scale(.5)}
  20%{opacity:.7}
  80%{opacity:.5}
  100%{opacity:0;transform:translateY(-80px) scale(1.2)}
}
.pt-blue{background:var(--teal)}

/* ─── NAV ─────────────────────────────────────────── */
nav{position:fixed;top:0;left:0;right:0;z-index:200;padding:1.2rem 2.5rem;display:flex;justify-content:space-between;align-items:center;backdrop-filter:blur(12px);background:rgba(1,9,5,.55);border-bottom:1px solid rgba(0,229,128,.08)}
.nl{font-family:'Syne',sans-serif;font-size:1.1rem;font-weight:700;letter-spacing:.25em;color:var(--bright);text-transform:uppercase}
.nc{font-family:'Syne',sans-serif;font-size:.7rem;font-weight:600;letter-spacing:.18em;text-transform:uppercase;color:var(--deep);background:var(--bright);padding:.6rem 1.5rem;cursor:pointer;border:none;transition:all .25s}
.nc:hover{background:var(--teal)}

/* ─── HERO ────────────────────────────────────────── */
#hero{position:relative;z-index:1;height:100vh;display:flex;flex-direction:column;align-items:center;justify-content:center;overflow:hidden;padding:0 1.5rem}
.hero-glow{position:absolute;width:600px;height:600px;background:radial-gradient(circle,rgba(0,229,128,.12) 0%,transparent 65%);border-radius:50%;pointer-events:none;animation:gPulse 4s ease-in-out infinite}
@keyframes gPulse{0%,100%{transform:scale(.95);opacity:.8}50%{transform:scale(1.05);opacity:1}}
#hero-watch{position:relative;z-index:2;animation:watchFloat 5s ease-in-out infinite;filter:drop-shadow(0 20px 40px rgba(0,229,128,.15)) drop-shadow(0 0 60px rgba(0,196,204,.08))}
@keyframes watchFloat{0%,100%{transform:translateY(0) rotate(0deg)}50%{transform:translateY(-10px) rotate(.3deg)}}
.gleam{position:absolute;top:0;left:0;right:0;bottom:0;border-radius:50%;background:conic-gradient(transparent 0deg,transparent 250deg,rgba(168,240,216,.12) 280deg,transparent 310deg);animation:gleamSpin 6s linear infinite;pointer-events:none}
.hero-eyebrow{font-family:'Syne',sans-serif;font-size:.65rem;font-weight:600;letter-spacing:.55em;text-transform:uppercase;color:var(--bright);text-align:center;margin-top:2rem;opacity:0}
.hero-title{font-family:'Syne',sans-serif;font-size:clamp(4rem,11vw,9.5rem);font-weight:800;letter-spacing:-.02em;color:var(--text);text-align:center;line-height:.95;margin-top:.6rem;opacity:0}
.hero-title em{color:var(--bright);font-style:normal}
.hero-sub{font-size:clamp(.85rem,1.8vw,1rem);font-weight:300;color:rgba(216,242,232,.55);text-align:center;margin-top:1.2rem;letter-spacing:.04em;opacity:0;max-width:420px}
.scroll-hint{position:absolute;bottom:2rem;left:50%;transform:translateX(-50%);display:flex;flex-direction:column;align-items:center;gap:.6rem;opacity:0}
.scroll-hint span{font-size:.6rem;letter-spacing:.4em;text-transform:uppercase;color:var(--muted)}
.scroll-track{width:1px;height:52px;position:relative;overflow:hidden;background:rgba(0,229,128,.15)}
.scroll-dot{width:1px;height:20px;background:var(--bright);position:absolute;top:-20px;animation:sdrop 1.8s ease-in-out infinite}
@keyframes sdrop{0%{top:-20px;opacity:1}100%{top:52px;opacity:0}}

/* ─── SHARED ──────────────────────────────────────── */
.ch-eyebrow{font-family:'Syne',sans-serif;font-size:.62rem;font-weight:600;letter-spacing:.5em;text-transform:uppercase;color:var(--bright)}
.ch-title{font-family:'Syne',sans-serif;font-size:clamp(2.2rem,4.5vw,4.2rem);font-weight:700;color:var(--text);line-height:1.05;margin-top:.7rem}
.ch-body{font-size:.95rem;line-height:1.85;color:rgba(216,242,232,.6);max-width:440px}
.hl{width:32px;height:2px;background:var(--bright);margin:1.6rem 0;border-radius:1px}
.btn-g{display:inline-block;padding:.9rem 2.6rem;background:var(--bright);color:var(--deep);font-family:'Syne',sans-serif;font-size:.72rem;font-weight:700;letter-spacing:.2em;text-transform:uppercase;cursor:pointer;border:none;transition:all .22s;text-decoration:none}
.btn-g:hover{background:var(--teal);transform:translateY(-2px)}
.btn-o{display:inline-block;padding:.9rem 2.6rem;background:transparent;color:var(--text);font-family:'Syne',sans-serif;font-size:.72rem;font-weight:600;letter-spacing:.2em;text-transform:uppercase;cursor:pointer;border:1px solid rgba(0,229,128,.3);transition:all .22s;text-decoration:none}
.btn-o:hover{border-color:var(--bright);color:var(--bright)}

/* ─── EXPLODE SECTION ─────────────────────────────── */
#explode-wrapper{position:relative;z-index:1}
#explode{height:100vh;display:flex;align-items:center;justify-content:center;position:relative;overflow:hidden}
#explode-bg-overlay{position:absolute;inset:0;background:linear-gradient(135deg,rgba(0,229,128,.04) 0%,transparent 60%,rgba(0,196,204,.04) 100%);pointer-events:none}

.xscene{position:relative;width:min(700px,100vw);height:min(620px,90vh);display:flex;align-items:center;justify-content:center}

/* Each watch part – absolutely centered, will be animated */
.wpart{position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);will-change:transform,opacity;cursor:default}
.wpart svg{display:block}

/* Labels */
.wlabel{position:absolute;opacity:0;will-change:opacity,transform;pointer-events:none}
.wl-name{font-family:'Syne',sans-serif;font-size:.85rem;font-weight:600;color:var(--text);letter-spacing:.05em}
.wl-sub{font-family:'DM Sans',sans-serif;font-size:.62rem;font-weight:400;letter-spacing:.18em;text-transform:uppercase;color:var(--bright);margin-top:.25rem}
.wl-line{position:absolute;background:rgba(0,229,128,.35);height:1px}

/* explode heading + CTA */
#x-head{position:absolute;top:6%;left:50%;transform:translateX(-50%);text-align:center;opacity:0;white-space:nowrap}
#x-cta{position:absolute;bottom:5%;left:50%;transform:translateX(-50%);text-align:center;opacity:0;white-space:nowrap}

/* ─── WOOD ────────────────────────────────────────── */
#wood{position:relative;z-index:1;min-height:100vh;display:flex;align-items:center;overflow:hidden;background:linear-gradient(180deg,transparent 0%,rgba(4,20,10,.85) 20%,rgba(4,20,10,.85) 80%,transparent 100%)}
.wood-inner{display:grid;grid-template-columns:1fr 1fr;gap:4rem;align-items:center;max-width:1100px;margin:0 auto;padding:7rem 3rem}
.wstats{display:grid;grid-template-columns:1fr 1fr;gap:1.4rem;margin-top:2.5rem}
.ws{border-left:1px solid rgba(0,229,128,.3);padding-left:.9rem}
.ws-n{font-family:'Syne',sans-serif;font-size:2.2rem;font-weight:700;color:var(--bright);line-height:1}
.ws-l{font-size:.65rem;letter-spacing:.2em;text-transform:uppercase;color:rgba(216,242,232,.4);margin-top:.3rem}

/* ─── MOVEMENT ────────────────────────────────────── */
#movement-wrapper{position:relative;z-index:1}
#movement{height:100vh;display:flex;align-items:center;justify-content:center;position:relative;overflow:hidden}
.mstage{display:grid;grid-template-columns:1fr 1fr;gap:3rem;align-items:center;max-width:1100px;width:100%;padding:0 3rem}

/* Insight cards for accessible movement explanation */
.insights{display:flex;flex-direction:column;gap:.9rem;margin-top:2rem}
.insight{display:flex;align-items:flex-start;gap:1rem;padding:1rem 1.2rem;border:1px solid rgba(0,229,128,.12);background:rgba(0,229,128,.03);transition:all .3s}
.insight:hover{border-color:rgba(0,229,128,.3);background:rgba(0,229,128,.06)}
.i-num{font-family:'Syne',sans-serif;font-size:1.6rem;font-weight:800;color:var(--bright);opacity:.4;line-height:1;min-width:2.5rem}
.i-text strong{display:block;font-family:'Syne',sans-serif;font-size:.82rem;font-weight:600;color:var(--text);margin-bottom:.2rem;letter-spacing:.04em}
.i-text span{font-size:.8rem;color:rgba(216,242,232,.5);line-height:1.55}

/* ─── CTA ─────────────────────────────────────────── */
#fcta{position:relative;z-index:1;min-height:100vh;display:flex;align-items:center;justify-content:center;text-align:center;padding:4rem 2rem;overflow:hidden}
.fcta-glow{position:absolute;width:700px;height:700px;background:radial-gradient(circle,rgba(0,229,128,.1) 0%,transparent 60%);border-radius:50%;pointer-events:none}
.fcta-inner{position:relative;z-index:2}
.price-block{margin:2rem 0}
.price-from{font-size:.7rem;letter-spacing:.35em;text-transform:uppercase;color:var(--muted)}
.price-amt{font-family:'Syne',sans-serif;font-size:4.5rem;font-weight:800;color:var(--text);display:block;margin-top:.3rem;line-height:1}
.cta-btns{display:flex;gap:1rem;justify-content:center;margin-top:2.5rem;flex-wrap:wrap}
.trust{display:flex;gap:1.8rem;justify-content:center;margin-top:2rem;flex-wrap:wrap}
.ti{font-size:.68rem;letter-spacing:.18em;text-transform:uppercase;color:var(--muted);display:flex;align-items:center;gap:.4rem}
.ti::before{content:'';width:4px;height:4px;border-radius:50%;background:var(--bright);display:block}
.reviews{display:flex;align-items:center;justify-content:center;gap:.5rem;margin-top:1.4rem}
.stars{color:var(--bright);letter-spacing:.1em;font-size:1rem}
.rev-txt{font-size:.78rem;color:var(--muted);letter-spacing:.08em}
.ft{margin-top:5rem;font-size:.6rem;letter-spacing:.4em;text-transform:uppercase;opacity:.18;font-family:'Syne',sans-serif}

/* ─── MOBILE ──────────────────────────────────────── */
@media(max-width:768px){
  nav{padding:1rem 1.2rem}
  .nc{padding:.5rem 1rem;font-size:.65rem}
  .wood-inner{grid-template-columns:1fr;padding:5rem 1.5rem;gap:3rem}
  .mstage{grid-template-columns:1fr;padding:0 1.5rem;gap:2.5rem}
  #movement{height:auto;padding:5rem 0}
  .mstage > div:first-child{display:flex;justify-content:center}
  #gear-svg{width:280px;height:280px}
  .xscene{height:70vh}
}
@media(max-width:480px){
  .hero-title{font-size:3.5rem}
  .xscene{width:100vw;height:85vh}
  .wl-name{font-size:.75rem}
  .wl-sub{font-size:.56rem}
}
</style>
</head>
<body>

