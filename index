<!-- ─── NAV ────────────────────────────────────────── -->
<nav>
  <div class="nl">Truwood</div>
  <button class="nc" onclick="document.getElementById('fcta').scrollIntoView({behavior:'smooth'})">Add to Cart — $259</button>
</nav>

<!-- ─── HERO ───────────────────────────────────────── -->
<section id="hero">
  <div class="hero-glow"></div>
  <div id="hero-watch" style="position:relative">
    <!-- Pilot Chronograph Watch SVG -->
    <svg viewBox="0 0 240 380" width="240" height="380" fill="none" xmlns="http://www.w3.org/2000/svg">
      <defs>
        <linearGradient id="hbg" x1="0" y1="0" x2="240" y2="380" gradientUnits="userSpaceOnUse">
          <stop offset="0%" stop-color="#0C200A"/>
          <stop offset="100%" stop-color="#040C04"/>
        </linearGradient>
        <radialGradient id="hdial" cx="45%" cy="38%" r="65%">
          <stop offset="0%" stop-color="#181A16"/>
          <stop offset="100%" stop-color="#090A08"/>
        </radialGradient>
        <linearGradient id="hcrown" x1="0" y1="0" x2="1" y2="0">
          <stop offset="0%" stop-color="#1A4028"/>
          <stop offset="100%" stop-color="#00802A"/>
        </linearGradient>
        <filter id="glow"><feGaussianBlur stdDeviation="3" result="b"/><feMerge><feMergeNode in="b"/><feMergeNode in="SourceGraphic"/></feMerge></filter>
      </defs>
      <!-- Wood band links - top -->
      <rect x="84" y="0" width="72" height="14" rx="5" fill="#1A3010"/>
      <rect x="84" y="14" width="72" height="12" rx="4" fill="#152808"/>
      <rect x="86" y="26" width="68" height="12" rx="4" fill="#1A3010"/>
      <rect x="88" y="38" width="64" height="10" rx="4" fill="#152808"/>
      <rect x="90" y="48" width="60" height="14" rx="4" fill="#1A3010"/>
      <!-- Wood link grain lines top -->
      <line x1="96" y1="4" x2="96" y2="11" stroke="rgba(0,229,128,.1)" stroke-width=".8"/>
      <line x1="120" y1="4" x2="120" y2="11" stroke="rgba(0,229,128,.08)" stroke-width=".8"/>
      <line x1="144" y1="4" x2="144" y2="11" stroke="rgba(0,229,128,.1)" stroke-width=".8"/>
      <!-- Case shadow -->
      <rect x="14" y="60" width="212" height="260" rx="54" fill="#010A04"/>
      <!-- Main case – 45mm black sandalwood -->
      <rect x="18" y="64" width="204" height="252" rx="50" fill="url(#hbg)"/>
      <rect x="18" y="64" width="204" height="252" rx="50" stroke="rgba(0,229,128,.3)" stroke-width="1.5" fill="none"/>
      <!-- Inner bezel -->
      <rect x="26" y="72" width="188" height="236" rx="44" fill="none" stroke="rgba(0,229,128,.1)" stroke-width=".8"/>
      <!-- Lugs -->
      <rect x="72" y="70" width="28" height="16" rx="5" fill="#0F2810"/>
      <rect x="140" y="70" width="28" height="16" rx="5" fill="#0F2810"/>
      <rect x="72" y="294" width="28" height="16" rx="5" fill="#0F2810"/>
      <rect x="140" y="294" width="28" height="16" rx="5" fill="#0F2810"/>
      <!-- Crown -->
      <rect x="216" y="175" width="22" height="16" rx="6" fill="url(#hcrown)"/>
      <rect x="216" y="175" width="22" height="16" rx="6" stroke="rgba(0,229,128,.5)" stroke-width=".8" fill="none"/>
      <!-- Pushers -->
      <rect x="218" y="152" width="16" height="8" rx="3" fill="#0D2010"/>
      <rect x="218" y="152" width="16" height="8" rx="3" stroke="rgba(0,229,128,.3)" stroke-width=".6" fill="none"/>
      <rect x="218" y="216" width="16" height="8" rx="3" fill="#0D2010"/>
      <rect x="218" y="216" width="16" height="8" rx="3" stroke="rgba(0,229,128,.3)" stroke-width=".6" fill="none"/>
      <!-- Dial -->
      <circle cx="120" cy="190" r="82" fill="url(#hdial)"/>
      <!-- Dial texture -->
      <circle cx="120" cy="190" r="82" fill="none" stroke="rgba(0,229,128,.08)" stroke-width="1"/>
      <!-- Hour indices -->
      <g fill="rgba(0,229,128,.8)">
        <rect x="117.5" y="116" width="5" height="12" rx="1.5"/>
        <rect x="117.5" y="252" width="5" height="12" rx="1.5"/>
        <rect x="176" y="187.5" width="12" height="5" rx="1.5"/>
        <rect x="52" y="187.5" width="12" height="5" rx="1.5"/>
      </g>
      <g fill="rgba(0,229,128,.45)">
        <rect x="149" y="124" width="4" height="8" rx="1" transform="rotate(30 151 128)"/>
