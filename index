            <line x1="252" y1="108" x2="252" y2="78" stroke="rgba(0,196,204,.4)" stroke-width="1.2"/>
            <line x1="252" y1="108" x2="278" y2="123" stroke="rgba(0,196,204,.4)" stroke-width="1.2"/>
            <line x1="252" y1="108" x2="226" y2="123" stroke="rgba(0,196,204,.4)" stroke-width="1.2"/>
            <g stroke="rgba(0,196,204,.55)" stroke-width="1.8" stroke-linecap="round">
              <line x1="252" y1="78" x2="252" y2="70"/><line x1="266" y1="82" x2="270" y2="74"/>
              <line x1="276" y1="93" x2="283" y2="88"/><line x1="281" y1="107" x2="289" y2="106"/>
              <line x1="279" y1="121" x2="287" y2="124"/><line x1="271" y1="134" x2="277" y2="140"/>
              <line x1="259" y1="141" x2="263" y2="149"/><line x1="244" y1="141" x2="241" y2="149"/>
              <line x1="233" y1="134" x2="227" y2="140"/><line x1="225" y1="121" x2="217" y2="124"/>
              <line x1="223" y1="107" x2="215" y2="106"/><line x1="228" y1="93" x2="221" y2="88"/>
              <line x1="238" y1="82" x2="234" y2="74"/>
            </g>
            <circle cx="252" cy="108" r="6" fill="rgba(0,196,204,.3)"/>
            <circle cx="252" cy="108" r="2.5" fill="var(--bright)" opacity=".7"/>
          </g>
          <!-- Balance wheel -->
          <g id="g3">
            <circle cx="262" cy="232" r="26" fill="rgba(0,229,128,.04)" stroke="rgba(0,229,128,.5)" stroke-width="2"/>
            <line x1="236" y1="232" x2="288" y2="232" stroke="rgba(0,229,128,.5)" stroke-width="1.5"/>
            <line x1="262" y1="206" x2="262" y2="258" stroke="rgba(0,229,128,.5)" stroke-width="1.5"/>
            <circle cx="236" cy="232" r="5" fill="rgba(0,229,128,.4)" filter="url(#mglow)"/>
            <circle cx="288" cy="232" r="5" fill="rgba(0,229,128,.4)" filter="url(#mglow)"/>
            <circle cx="262" cy="232" r="5" fill="var(--bright)" opacity=".7"/>
          </g>
          <!-- Barrel -->
          <g id="g4">
            <circle cx="98" cy="108" r="34" fill="rgba(0,196,204,.03)" stroke="rgba(0,196,204,.4)" stroke-width="1.5"/>
            <circle cx="98" cy="108" r="26" fill="none" stroke="rgba(0,196,204,.15)" stroke-width="1"/>
            <g stroke="rgba(0,196,204,.45)" stroke-width="1.8" stroke-linecap="round">
              <line x1="98" y1="74" x2="98" y2="65"/><line x1="115" y1="79" x2="119" y2="70"/>
              <line x1="127" y1="92" x2="133" y2="86"/><line x1="132" y1="108" x2="141" y2="108"/>
              <line x1="127" y1="124" x2="133" y2="130"/><line x1="115" y1="137" x2="119" y2="146"/>
              <line x1="98" y1="142" x2="98" y2="151"/><line x1="81" y1="137" x2="77" y2="146"/>
              <line x1="69" y1="124" x2="63" y2="130"/><line x1="64" y1="108" x2="55" y2="108"/>
              <line x1="69" y1="92" x2="63" y2="86"/><line x1="81" y1="79" x2="77" y2="70"/>
