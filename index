  </section>
</div>

<!-- ─── FINAL CTA ──────────────────────────────────── -->
<section id="fcta">
  <div class="fcta-glow"></div>
  <div class="fcta-inner" id="fcta-inner">
    <p class="ch-eyebrow">The Truwood Pilot</p>
    <h2 style="font-family:'Syne',sans-serif;font-size:clamp(3rem,7.5vw,7.5rem);font-weight:800;color:var(--text);line-height:.95;margin-top:.6rem">OWN YOUR<br><em style="color:var(--bright);font-style:normal">FOREST</em></h2>
    <div class="reviews">
      <span class="stars">★★★★★</span>
      <span class="rev-txt">4.9 · 2,841 reviews</span>
    </div>
    <div class="price-block">
      <span class="price-from">Starting from</span>
      <span class="price-amt">$259</span>
    </div>
    <div class="cta-btns">
      <button class="btn-g" style="padding:1.1rem 3.5rem;font-size:.82rem">Add to Cart</button>
      <button class="btn-o" style="padding:1.1rem 3.5rem">View All Models</button>
    </div>
    <div class="trust">
      <span class="ti">Free worldwide shipping</span>
      <span class="ti">1-year warranty</span>
      <span class="ti">30-day returns</span>
      <span class="ti">10 trees planted per order</span>
    </div>
    <p class="ft">Truwood Timepieces · Every order plants 10 trees · Est. 2019</p>
  </div>
</section>

<script>
gsap.registerPlugin(ScrollTrigger);

/* ─── PARTICLES ────────────────────────────────── */
(function createParticles(){
  const c=document.getElementById('particles');
  for(let i=0;i<35;i++){
    const p=document.createElement('div');
    p.className='pt'+(Math.random()>.6?' pt-blue':'');
    const s=1+Math.random()*2.5;
    p.style.cssText=`left:${Math.random()*100}vw;top:${20+Math.random()*70}vh;width:${s}px;height:${s}px;animation-delay:${Math.random()*10}s;animation-duration:${7+Math.random()*7}s`;
    c.appendChild(p);
  }
})();

/* ─── LIGHT SHAFTS ─────────────────────────────── */
(function createShafts(){
  const c=document.getElementById('shafts');
  const positions=[8,18,28,40,54,66,78,88];
  const durations=[22,28,18,32,24,20,26,30];
  positions.forEach((x,i)=>{
    const s=document.createElement('div');
    s.className='shaft';
    s.style.cssText=`left:${x}%;opacity:${.4+Math.random()*.6};animation-duration:${durations[i]}s;animation-delay:${-Math.random()*durations[i]}s;width:${40+Math.random()*60}px`;
    c.appendChild(s);
  });
})();

/* ─── HERO ANIMATION ───────────────────────────── */
gsap.set(['#hero-watch','#he','#ht','#hs','#sh'],{opacity:0});
gsap.set('#hero-watch',{y:40,scale:.92});
gsap.set(['#he','#ht'],{y:30});
gsap.set('#hs',{y:20});

gsap.timeline({delay:.4})
  .to('#hero-watch',{opacity:1,y:0,scale:1,duration:1.4,ease:'power3.out'})
  .to('#he',{opacity:1,y:0,duration:.8,ease:'power3.out'},0.55)
  .to('#ht',{opacity:1,y:0,duration:.9,ease:'power3.out'},0.7)
  .to('#hs',{opacity:1,y:0,duration:.8,ease:'power3.out'},0.9)
  .to('#sh',{opacity:1,duration:.6},1.3);

/* ─── FOREST PARALLAX ──────────────────────────── */
const layers=document.querySelectorAll('.tree-layer');
layers.forEach((l,i)=>{
  const speed=[0.15,0.35,0.6][i];
  gsap.to(l,{
    x:()=>-window.innerWidth*speed*0.3,
    ease:'none',
    scrollTrigger:{trigger:'body',start:'top top',end:'bottom bottom',scrub:1}
  });
  /* Gentle sway */
  gsap.to(l,{
    x:`+=${[8,12,18][i]}`,
    duration:[5,4,3][i],
    repeat:-1,yoyo:true,ease:'sine.inOut'
  });
});

/* ─── EXPLODE SETUP ────────────────────────────── */
/* Natural assembled positions (y offset from center) */
const assembled={
  'px-crystal': {y:-135, x:0,   r:0,   scale:.85},
  'px-dial':    {y:-100, x:0,   r:0,   scale:.85},
  'px-case':    {y:0,    x:0,   r:0,   scale:1},
  'px-move':    {y:120,  x:0,   r:0,   scale:.9},
  'px-back':    {y:150,  x:0,   r:0,   scale:1},
  'px-band-t':  {y:-200, x:0,   r:0,   scale:.8},
  'px-band-b':  {y:220,  x:0,   r:0,   scale:.8},
};
/* Exploded positions */
const exploded={
  'px-crystal': {y:-240, x:0,    r:0,   scale:1},
  'px-dial':    {y:-145, x:0,    r:0,   scale:1},
  'px-case':    {y:0,    x:0,    r:0,   scale:1},
  'px-move':    {y:170,  x:0,    r:0,   scale:1},
  'px-back':    {y:270,  x:0,    r:0,   scale:1},
  'px-band-t':  {y:-340, x:0,    r:0,   scale:1},
  'px-band-b':  {y:390,  x:0,    r:0,   scale:1},
};

/* Label positions (matching exploded) */
const labelPos={
  'lx-crystal': {y:-240},
  'lx-dial':    {y:-145},
  'lx-case':    {y:0},
  'lx-move':    {y:170},
  'lx-back':    {y:270},
  'lx-band-t':  {y:-340},
  'lx-band-b':  {y:390},
};

/* Set initial assembled positions */
Object.entries(assembled).forEach(([id,pos])=>{
  gsap.set(`#${id}`,{x:pos.x,y:pos.y,rotation:pos.r,scale:pos.scale,opacity:0});
});
/* Position labels at exploded Y */
Object.entries(labelPos).forEach(([id,pos])=>{
  gsap.set(`#${id}`,{y:pos.y,opacity:0,x:0});
});
gsap.set('#x-head',{opacity:0,y:-16});
gsap.set('#x-cta',{opacity:0,y:16});

const xtl=gsap.timeline({
  scrollTrigger:{
    trigger:'#explode-wrapper',
    start:'top top',
    end:'+=3200',
    pin:true,
    scrub:1.2,
    anticipatePin:1,
  }
});

/* 0-8%: heading fades in */
xtl.to('#x-head',{opacity:1,y:0,duration:.1},0);

/* 5-15%: all parts fade in at assembled positions */
Object.keys(assembled).forEach((id,i)=>{
  xtl.to(`#${id}`,{opacity:1,duration:.08},0.05+i*.01);
});

/* 15-60%: parts separate to exploded positions */
Object.entries(exploded).forEach(([id,pos])=>{
  xtl.to(`#${id}`,{y:pos.y,scale:pos.scale,duration:.45,ease:'power2.out'},0.15);
});

/* 60-80%: labels fade in */
Object.keys(labelPos).forEach((id,i)=>{
  xtl.to(`#${id}`,{opacity:1,duration:.1},0.6+i*.025);
});

/* 78-92%: CTA appears */
xtl.to('#x-cta',{opacity:1,y:0,duration:.14},0.8);

/* ─── GEAR ANIMATIONS ──────────────────────────── */
gsap.to('#g1',{rotation:360, transformOrigin:'170px 170px',duration:6,  repeat:-1,ease:'none'});
gsap.to('#g2',{rotation:-360,transformOrigin:'252px 108px',duration:4,  repeat:-1,ease:'none'});
gsap.to('#g4',{rotation:360, transformOrigin:'98px 108px', duration:8,  repeat:-1,ease:'none'});
gsap.to('#g3',{rotation:22,  transformOrigin:'262px 232px',duration:.4, repeat:-1,yoyo:true,ease:'sine.inOut'});

/* ─── MOVEMENT PIN ─────────────────────────────── */
ScrollTrigger.create({
  trigger:'#movement-wrapper',
  start:'top top',
  end:'+=1800',
  pin:true,
  anticipatePin:1,
});

gsap.from('#mvis',{
  scrollTrigger:{trigger:'#movement-wrapper',start:'top 85%',end:'top 15%',scrub:1},
  x:-60,opacity:0
});
gsap.from('#mtxt > *',{
  scrollTrigger:{trigger:'#movement-wrapper',start:'top 85%',end:'top 20%',scrub:.8},
  x:50,opacity:0,stagger:.08
});

/* ─── WOOD SECTION ─────────────────────────────── */
gsap.from('#wood-txt > *',{
  scrollTrigger:{trigger:'#wood',start:'top 80%',end:'top 20%',scrub:.8},
  x:-50,opacity:0,stagger:.1
});
gsap.from('#wood-vis',{
  scrollTrigger:{trigger:'#wood',start:'top 80%',end:'top 20%',scrub:.8},
  x:50,opacity:0,scale:.9
});

/* ─── FINAL CTA ────────────────────────────────── */
gsap.from('#fcta-inner > *',{
  scrollTrigger:{trigger:'#fcta',start:'top 75%',end:'top 15%',scrub:.7},
  y:50,opacity:0,stagger:.08
});
</script>
</body>
</html>
